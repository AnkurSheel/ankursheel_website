@using StatiqHelpers.Models
@model BaseModel

@{
 var tableOfContents = Model.Document.GetTableOfContents();
}

@if (tableOfContents.Any())
{
    <div class="lg:hidden not-prose">
        <details class="mb-8 p-4 bg-gray-100 rounded-lg shadow-inner group">
            <summary class="flex justify-between items-center cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                <span class="text-lg font-bold">Table of Contents</span>
                <svg class="w-6 h-6 transition-transform duration-200 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
            </summary>
            <div class="mt-4">
                <ul class="list-none space-y-2">
                    @foreach (var entry in tableOfContents)
                    {
                        <li class="@(entry.Level == 2 ? "font-semibold" : entry.Level == 3 ? "ml-4" : "ml-8")">
                            <a href="#@entry.Id" class="text-blue-600 hover:text-blue-800 transition-colors duration-200">@entry.Title</a>
                        </li>
                    }
                </ul>
            </div>
        </details>
    </div>

    <aside class="hidden lg:block fixed left-6 top-0 h-screen w-64 overflow-y-auto pt-28 pb-4">
        <nav class="p-4 bg-gray-100 rounded-lg shadow-inner prose-sm not-prose">
            <h2 class="m-0 mb-3 text-lg font-bold">Table of Contents</h2>
            <ul class="m-0 list-none space-y-2">
                @foreach (var entry in tableOfContents)
                {
                    <li class="@(entry.Level == 2 ? "font-semibold" : entry.Level == 3 ? "ml-4" : "ml-8")">
                        <a href="#@entry.Id" class="text-blue-600 hover:text-blue-800 transition-colors duration-200">@entry.Title</a>
                    </li>
                }
            </ul>
        </nav>
    </aside>
}
